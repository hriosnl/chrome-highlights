{
  "manifest_version": 3,
  "name": "Highlights",
  "version": "2.0.0",
  "description": "Highlight text on webpages. Saves highlights locally with notes.",
  "permissions": ["storage", "contextMenus", "activeTab", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/url.js", "shared/colors.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Highlights",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "highlight-selection": {
      "suggested_key": {
        "default": "Alt+H",
        "mac": "MacCtrl+H"
      },
      "description": "Highlight selected text"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["library.html", "library.css", "library.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
